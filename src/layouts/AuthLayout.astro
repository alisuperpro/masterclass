---
import {
  SignedIn,
  SignedOut,
  UserButton,
  SignInButton,
  SignUpButton,
} from "@clerk/astro/components"
import "../styles/global.css"

interface Props {
  title?: string
}

const { title = "Cache Marketing" } = Astro.props
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="flex flex-row justify-end items-center px-4 py-4">
      <div>
        <SignedOut>
          <SignInButton mode="modal" fallbackRedirectUrl="/perfil" />
          <SignUpButton
            mode="modal"
            fallbackRedirectUrl="/informacion-adicional"
          />
        </SignedOut>
        <SignedIn>
          <div class="flex flex-row justify-center items-center gap-x-4">
            <a href="/">Inicio</a>
            <a href="/perfil">Ver Perfil</a>
            <UserButton />
          </div>
        </SignedIn>
      </div>
    </header>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
