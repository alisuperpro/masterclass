---
import AuthLayout from "@/layouts/AuthLayout.astro"
---

<AuthLayout>
  <section class="px-8 grid grid-cols-3">
    <div class="col-span-full flex flex-col justify-center items-center">
      <h1 id="user-name" class="font-bold text-3xl"></h1>
      <div class="flex flex-row py-2 justify-center items-center gap-x-12">
        <span id="user-doc-id" class="text-gray-400"></span>
        <span id="user-ig-username" class="text-gray-400"></span>
        <span id="user-phone" class="text-gray-400"></span>
      </div>
    </div>
  </section>
</AuthLayout>

<script>
  import { API_URL } from "@/lib/const"

  document.addEventListener("DOMContentLoaded", async () => {
    const $username = document.getElementById("user-name") as HTMLElement
    const $userDocId = document.getElementById("user-doc-id") as HTMLElement
    const $userIgUsername = document.getElementById(
      "user-ig-username",
    ) as HTMLElement
    const $userPhone = document.getElementById("user-phone") as HTMLElement
    const res = await fetch("/api/user", {
      method: "GET",
    })

    const json = await res.json()

    const { id } = json.user
    const { token } = json
    const userFetch = await fetch(`${API_URL}/api/user/me/${id}`, {
      method: "GET",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${token}`,
        "Access-Control-Allow-Headers": "*",
        mode: "cors",
      },
    })

    if (userFetch.status === 404) {
      location.href = "/informacion-adicional"
    }

    const userData = await userFetch.json()

    const user = userData.data

    $username.innerText = user.full_name
    $userDocId.innerText = user.doc_id
    $userIgUsername.innerText = `@${user.ig_username}`
    $userPhone.innerText = user.phone
  })
</script>
