  },
]
---

<div
  class="grid md:grid-cols-9 grid-cols-3 gap-x-2 gap-y-2 md:gap-x-4 px-4 md:px-8 pb-4 md:pb-0"
>
  {
    SPONSORS.map((el) => (
      <div class="flex justify-center items-center sponsors">
        <a href={el.contact} rel="noopener noreferrer" target="_blank">
          <img
            src={el.img}
            alt={"Cache marketing Patrocinadores"}
            id={el.name}
            class={el.class ? el.class : "w-28"}
            loading="eager"
          />
        </a>
      </div>
    ))
  }
</div>

<script>
  import { gsap } from "gsap"

  gsap.from(".sponsors", { opacity: 0 })
  gsap.to(".sponsors", {
    opacity: 1,
    ease: "linear",
    duration: 3,
    stagger: {
      each: 0.1,
      from: "end",
    },
  })
</script>
