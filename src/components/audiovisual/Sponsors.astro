    class: "w-20 md:w-24",
  },

  {
    name: "cafe-de-tus-sueños",
    img: "/sponsors/cafe-de-tus-sueños.avif",
    contact: "https://www.instagram.com/keilamartiarena",
    class: "w-24 md:w-32",
  },

  {
    name: "claj",
    img: "/sponsors/claj.avif",
    contact: "https://www.instagram.com/clajsistec",
    class: "w-20 md:w-24",
  },

  {
    name: "bubbers",
    img: "/sponsors/bubbers.avif",
    class: "w-14 md:w-20",
    contact: "https://www.instagram.com/bubbersccpmaturin",
  },
  {
    name: "confenacap",
    img: "/sponsors/confenacap.avif",
    class: "w-20 md:w-28",
    contact: "",
  },
  {
    name: "bn-publicidad",
    img: "/sponsors/bn-publicidad.avif",
    class: "md:w-44 w-28 md:mb-4",
    contact: "https://www.instagram.com/bnpublicidad.ve",
  },

  {
    name: "mario-garcia",
    img: "/sponsors/mario-garcia.avif",
    class: "w-28 md:w-40",
    contact: "https://www.instagram.com/od.mariogarcia",
  },
  {
    name: "hotel-tibisay",
